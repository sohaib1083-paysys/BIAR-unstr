NODE_ENV=development
FUNCTION_NAME=biar-processor

# CouchDB Configuration
COUCHDB_URL=http://localhost:5984/cms-evidence

# Processing Services
TIKA_URL=http://localhost:9998
SOLR_URL=http://localhost:8983/solr/biar
NIFI_URL=http://localhost:8080/nifi-api

# Cron Configuration - runs every 30 seconds
CRON_ENABLED=true
CRON_SCHEDULE=*/30 * * * * *

# Processing Limits
MAX_FILE_SIZE_MB=50
MAX_SOLR_CONTENT=1000000
TIKA_TIMEOUT=30000
NIFI_TIMEOUT=30000
